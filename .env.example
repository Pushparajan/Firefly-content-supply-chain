# ============================================================
# Adobe App Builder – Content Supply Chain
# Copy this file to .env and populate before local development
# NEVER commit .env to source control
# ============================================================

# --- IMS / OAuth Server-to-Server (from Adobe Developer Console) ---
AIO_IMS_CONTEXT_NAME=aio-lib-ims-jwt
AIO_IMS_ORG_ID=XXXXXXXXXXXXXXXXXXXXXXXX@AdobeOrg
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
TECHNICAL_ACCOUNT_ID=XXXXXXXXXXXXXXXXXXXXXXXX@techacct.adobe.com
TECHNICAL_ACCOUNT_EMAIL=your-technical-account@techacct.adobe.com

# --- Adobe Firefly V3 ---
FIREFLY_API_BASE_URL=https://firefly-api.adobe.io
# Public HTTPS URL to the brand hero image stored in AEM or CDN
BRAND_STYLE_REFERENCE_URL=https://your-aem-instance/content/dam/brand/hero-reference.jpg
FIREFLY_NUM_VARIATIONS=4
FIREFLY_POLL_INTERVAL_MS=5000
FIREFLY_POLL_MAX_ATTEMPTS=60
# Optional: Firefly for Enterprise custom model ID (from Firefly admin console)
# When set, overrides the standard Firefly base model with a brand-trained model
FIREFLY_CUSTOM_MODEL_ID=

# --- AEM as a Cloud Service ---
AEM_HOST=https://author-pXXXX-eYYYY.adobeaemcloud.com
AEM_UPLOAD_BASE_PATH=/content/dam/generated-assets
AEM_BATCH_UPLOAD_ENABLED=true

# --- Adobe Workfront ---
WORKFRONT_BASE_URL=https://your-instance.my.workfront.com
WORKFRONT_API_KEY=your-workfront-api-key
WORKFRONT_API_VERSION=17.0

# --- AEM Publish (for offer representation URLs) ---
AEM_PUBLISH_HOST=https://publish-pXXXX-eYYYY.adobeaemcloud.com

# --- Adobe Experience Platform / Real-Time CDP ---
AEP_SANDBOX_NAME=prod
# Streaming Inlet URL from Data Collection UI → Datastreams → Streaming endpoint
AEP_STREAMING_INLET_URL=https://dcs.adobedc.net/collection/YOUR_INLET_ID
# AEP dataset ID where XDM ExperienceEvents are written (must have ExperienceEvent schema)
AEP_DATASET_ID=your-aep-dataset-id
# XDM schema $id for the ExperienceEvent dataset
AEP_SCHEMA_REF=https://ns.adobe.com/your-org/schemas/your-schema-id

# --- AJO Offer Decisioning ---
# Deployed URL of the offer-sync App Builder action (set after first deploy)
OFFER_SYNC_ACTION_URL=https://YOUR_NAMESPACE.adobeioruntime.net/api/v1/web/content-supply-chain/offer-sync

# --- Campaign defaults ---
# Default campaign code when not present in Workfront custom form (DE_campaign_code)
CAMPAIGN_CODE=DEFAULT-CAMPAIGN

# --- Adobe Content Hub (Brand Portal) ---
# Tenant-specific Brand Portal host — agencies upload raw creatives here
CONTENT_HUB_HOST=https://your-tenant.brand-portal.adobe.com
# AEM DAM path configured as the agency contribution folder in Content Hub
CONTENT_HUB_CONTRIBUTION_PATH=/ACME/contributions

# --- Security ---
# HMAC-SHA256 secret configured in Workfront Event Subscriptions
WORKFRONT_WEBHOOK_SECRET=your-webhook-hmac-secret
# Shared secret between Workfront Fusion HTTP module and fusion-ingest action
FUSION_INGEST_SECRET=your-fusion-ingest-secret
