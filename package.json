{
  "name": "firefly-content-supply-chain",
  "version": "1.0.0",
  "description": "Adobe App Builder – Content Supply Chain orchestration: Workfront → Firefly V3 → AEM Assets",
  "main": "actions/orchestrate/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint actions/ lib/ --ext .js",
    "lint:fix": "eslint actions/ lib/ --ext .js --fix",
    "deploy": "aio app deploy",
    "undeploy": "aio app undeploy",
    "build": "aio app build"
  },
  "dependencies": {
    "@adobe/aio-lib-core-logging": "^3.0.5",
    "@adobe/aio-sdk": "^4.0.1",
    "@adobe/firefly-apis": "^1.0.4",
    "@adobe/firefly-services-common-apis": "^1.0.4",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "nock": "^13.5.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathPattern": "test/unit",
    "collectCoverageFrom": [
      "actions/**/*.js",
      "lib/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80
      }
    }
  }
}
